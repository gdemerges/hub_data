{
  "name": "hub-medias",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "npm run build:data && next build",
    "vercel-build": "next build",
    "build:data": "tsx scripts/build-data.ts --skip-download",
    "update:data": "tsx scripts/build-data.ts",
    "update:data:quick": "tsx scripts/build-data.ts --skip-download",
    "start": "next start",
    "lint": "biome lint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "analyze": "ANALYZE=true next build",
    "steam:sync": "curl -X POST http://localhost:3000/api/steam/sync",
    "refresh:covers": "tsx scripts/refresh-covers.ts",
    "refresh:book-covers": "tsx scripts/refresh-book-covers.ts",
    "track:play-deltas": "tsx scripts/track-play-deltas.ts",
    "format": "biome format --write .",
    "check": "biome check ."
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-virtual": "^3.13.13",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.468.0",
    "next": "^15.5.16",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-simple-maps": "^3.0.0",
    "swr": "^2.3.8",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@next/bundle-analyzer": "^16.2.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/ui": "^4.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "csv-parse": "^5.6.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
