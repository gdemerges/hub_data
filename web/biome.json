{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": ["**", "!**/data", "!**/.next-verify", "!**/public/sw.js", "!**/*.css"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "space",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"useButtonType": "warn",
				"noStaticElementInteractions": "warn",
				"useKeyWithClickEvents": "warn",
				"noSvgWithoutTitle": "warn",
				"useAriaPropsSupportedByRole": "warn",
				"noLabelWithoutControl": "warn",
				"useSemanticElements": "warn",
				"useIframeTitle": "warn",
				"noAutofocus": "warn",
				"noInteractiveElementToNoninteractiveRole": "warn",
				"noNoninteractiveElementToInteractiveRole": "warn"
			},
			"style": {
				"noNonNullAssertion": "off"
			},
			"suspicious": {
				"noArrayIndexKey": "warn",
				"noCommentText": "warn",
				"useIterableCallbackReturn": "warn"
			},
			"performance": {
				"noImgElement": "off"
			},
			"complexity": {
				"noImportantStyles": "off"
			},
			"correctness": {
				"useExhaustiveDependencies": "warn"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"jsxQuoteStyle": "double",
			"semicolons": "asNeeded",
			"trailingCommas": "all",
			"arrowParentheses": "always"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
